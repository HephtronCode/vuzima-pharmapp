# Docker and shared local defaults
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vuzima
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://cache:6379

NODE_ENV=development
API_PORT=3000
CLIENT_PORT=5173
CLIENT_ORIGIN=http://localhost:5173

# Compose API container should talk to Postgres service host "db"
DATABASE_URL=postgresql://postgres:postgres@db:5432/vuzima
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

VITE_API_BASE_URL=http://localhost:3000
